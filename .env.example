# 本地示例环境变量
# 使用 pnpm install 后复制为 .env.local 或在系统环境中设置

# Supabase / Meoo Cloud 前端访问地址（若使用本地代理或直接 Supabase URL）
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# AI 服务（用于 functions/ai-chat）
AI_BASE_URL=https://api.meoo.host
AI_SERVICE_KEY=your_ai_service_key_here

# 额外：可配置应用名称
VITE_APP_NAME=company-admin-local
